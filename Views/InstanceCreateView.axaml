<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LauncherRoot.ViewModels"
             xmlns:views="clr-namespace:LauncherRoot.Views"
             x:Class="LauncherRoot.Views.InstanceCreateView">
  <Grid RowDefinitions="Auto,*,Auto" Margin="60,30">
    <!-- Header -->
    <StackPanel Grid.Row="0" HorizontalAlignment="Center" Spacing="8" Margin="0,10,0,24">
      <Border Height="2" Width="40"
              Background="{DynamicResource AccentBrush}"
              HorizontalAlignment="Center"
              CornerRadius="1" />
      <TextBlock Text="{Binding Localization[menu.newinstance]}"
                 IsVisible="{Binding IsEditing, Converter={StaticResource InverseBool}}"
                 Classes="h1" HorizontalAlignment="Center" />
      <TextBlock Text="{Binding Localization[instance.edit]}"
                 IsVisible="{Binding IsEditing}"
                 Classes="h1" HorizontalAlignment="Center" />
      <TextBlock Text="{Binding Localization[instance.createsub]}"
                 Classes="body" HorizontalAlignment="Center"
                 IsVisible="{Binding IsEditing, Converter={StaticResource InverseBool}}" />
      <TextBlock Text="{Binding Localization[instance.editsub]}"
                 Classes="body" HorizontalAlignment="Center"
                 IsVisible="{Binding IsEditing}" />
    </StackPanel>

    <!-- Content -->
    <ScrollViewer Grid.Row="1" HorizontalAlignment="Center">
      <StackPanel Spacing="16" Width="500">
        <TextBlock Text="{Binding Localization[instance.loading]}"
                   IsVisible="{Binding IsLoading}"
                   HorizontalAlignment="Center" Classes="body" />

        <!-- Version -->
        <Border Classes="card" Padding="20"
                IsVisible="{Binding IsLoading, Converter={StaticResource InverseBool}}">
          <StackPanel Spacing="10">
            <TextBlock Text="{Binding Localization[instance.version]}" Classes="h3" />
            <ComboBox ItemsSource="{Binding AvailableVersions}"
                      SelectedItem="{Binding SelectedVersion}"
                      Height="38" Width="340" HorizontalAlignment="Left" />
          </StackPanel>
        </Border>

        <!-- Loader -->
        <Border Classes="card" Padding="20"
                IsVisible="{Binding IsLoading, Converter={StaticResource InverseBool}}">
          <StackPanel Spacing="12">
            <TextBlock Text="{Binding Localization[instance.loader]}" Classes="h3" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
              <Button Command="{Binding SelectLoaderCommand}" CommandParameter="vanilla"
                      Width="76" Height="76" CornerRadius="14"
                      Background="{Binding IsVanilla, Converter={StaticResource BoolToBrush}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                  <TextBlock Text="Vanilla" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
              </Button>
              <Button Command="{Binding SelectLoaderCommand}" CommandParameter="fabric"
                      Width="76" Height="76" CornerRadius="14"
                      Background="{Binding IsFabric, Converter={StaticResource BoolToBrush}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                  <TextBlock Text="Fabric" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
              </Button>
              <Button Command="{Binding SelectLoaderCommand}" CommandParameter="forge"
                      Width="76" Height="76" CornerRadius="14"
                      Background="{Binding IsForge, Converter={StaticResource BoolToBrush}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                  <TextBlock Text="Forge" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
              </Button>
              <Button Command="{Binding SelectLoaderCommand}" CommandParameter="neoforge"
                      Width="76" Height="76" CornerRadius="14"
                      Background="{Binding IsNeoforge, Converter={StaticResource BoolToBrush}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                  <TextBlock Text="NeoForge" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
              </Button>
              <Button Command="{Binding SelectLoaderCommand}" CommandParameter="quilt"
                      Width="76" Height="76" CornerRadius="14"
                      Background="{Binding IsQuilt, Converter={StaticResource BoolToBrush}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                  <TextBlock Text="Quilt" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
              </Button>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Name -->
        <Border Classes="card" Padding="20"
                IsVisible="{Binding IsLoading, Converter={StaticResource InverseBool}}">
          <StackPanel Spacing="8">
            <TextBlock Text="{Binding Localization[instance.name]}"
                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBox Text="{Binding InstanceName}"
                     Height="40" FontSize="14"
                     Watermark="{Binding Localization[instance.name.placeholder]}" />
          </StackPanel>
        </Border>

        <!-- Group -->
        <Border Classes="card" Padding="20"
                IsVisible="{Binding IsLoading, Converter={StaticResource InverseBool}}">
          <StackPanel Spacing="8">
            <TextBlock Text="{Binding Localization[group.select]}"
                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
            <ComboBox ItemsSource="{Binding AvailableGroups}"
                      SelectedItem="{Binding SelectedGroup}"
                      Height="38" Width="340" HorizontalAlignment="Left" />
          </StackPanel>
        </Border>

        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource ErrorBrush}" FontSize="12"
                   HorizontalAlignment="Center" TextWrapping="Wrap" />
      </StackPanel>
    </ScrollViewer>

    <!-- Bottom buttons -->
    <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,*" Margin="0,20,0,10">
      <Button Command="{Binding BackCommand}" Classes="secondary"
              Width="120" Height="40" FontSize="13">
        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
          <TextBlock Text="←" FontSize="14" />
          <TextBlock Text="{Binding Localization[menu.back]}" />
        </StackPanel>
      </Button>
      <Button Command="{Binding CreateCommand}" Grid.Column="1"
              Classes="primary" Width="200" Height="44"
              FontSize="15" FontWeight="Bold" Margin="12,0,0,0"
              IsEnabled="{Binding IsCreating, Converter={StaticResource InverseBool}}">
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
          <TextBlock Text="+" FontSize="18" FontWeight="Bold"
                     IsVisible="{Binding IsEditing, Converter={StaticResource InverseBool}}" />
          <TextBlock Text="{Binding Localization[instance.create]}" VerticalAlignment="Center"
                     IsVisible="{Binding IsEditing, Converter={StaticResource InverseBool}}" />
          <TextBlock Text="{Binding Localization[instance.save]}" VerticalAlignment="Center"
                     IsVisible="{Binding IsEditing}" />
        </StackPanel>
      </Button>
    </Grid>
  </Grid>
</UserControl>
