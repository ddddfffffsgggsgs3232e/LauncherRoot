<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LauncherRoot.ViewModels"
             xmlns:models="clr-namespace:LauncherRoot.Models"
             x:Class="LauncherRoot.Views.MainMenuView">
  <Grid ColumnDefinitions="64,1,260,*">

    <!-- ═══════════ LEFT NAV SIDEBAR (XMCL-style) ═══════════ -->
    <Border Grid.Column="0"
            Background="{DynamicResource BgPrimaryBrush}">
      <Grid RowDefinitions="Auto,*,Auto">
        <!-- Logo + Nav Icons -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
          <!-- Logo -->
          <Border Margin="0,16,0,20">
            <Border Width="36" Height="36" CornerRadius="10"
                    Background="{DynamicResource AccentBrush}"
                    HorizontalAlignment="Center">
              <TextBlock Text="L" FontSize="18" FontWeight="Bold"
                         Foreground="#000000"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Border>
          </Border>

          <!-- Nav Icons -->
          <StackPanel Spacing="4">
            <!-- Home -->
            <Border Width="42" Height="42" CornerRadius="12"
                    Background="{DynamicResource AccentDimBrush}"
                    ToolTip.Tip="Home">
              <PathIcon Data="M 3,12 L 12,3 L 21,12 L 21,21 L 15,21 L 15,15 L 9,15 L 9,21 L 3,21 Z"
                        Width="18" Height="18"
                        Foreground="{DynamicResource AccentBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
            </Border>

            <!-- Mods -->
            <Button Classes="ghost" Width="42" Height="42"
                    Padding="0"
                    Command="{Binding OpenModManagementCommand}"
                    IsVisible="{Binding HasInstances}"
                    ToolTip.Tip="Mods">
              <PathIcon Data="M 20.5,11.5 L 19,7 L 15,7 L 15,3 L 9,3 L 9,7 L 5,7 L 3.5,11.5 L 3.5,22 L 20.5,22 Z M 9,5 L 15,5 L 15,7 L 9,7 Z M 5.5,9 L 8.5,9 L 8.5,14 L 5.5,14 Z M 15.5,9 L 18.5,9 L 18.5,14 L 15.5,14 Z M 5.5,16 L 8.5,16 L 8.5,20 L 5.5,20 Z M 15.5,16 L 18.5,16 L 18.5,20 L 15.5,20 Z M 10,10 L 14,10 L 14,14 L 10,14 Z M 10,16 L 14,16 L 14,20 L 10,20 Z"
                        Width="18" Height="18"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
            </Button>

            <!-- Settings -->
            <Button Classes="ghost" Width="42" Height="42"
                    Padding="0"
                    Command="{Binding OpenSettingsCommand}"
                    ToolTip.Tip="Settings">
              <PathIcon Data="M 12,15.5 A 3.5,3.5 0 1,1 12,8.5 A 3.5,3.5 0 1,1 12,15.5 M 19.4,13 C 19.2,12.7 19.1,12.4 19.1,12 C 19.1,11.6 19.2,11.3 19.4,11 L 21.5,9.3 C 21.7,9.2 21.7,8.8 21.5,8.6 L 19.5,5.1 C 19.4,4.9 19,4.9 18.8,5.1 L 16.7,6.7 C 16.2,6.3 15.7,6 15.1,5.8 L 14.7,3.6 C 14.7,3.3 14.4,3 14.1,3 L 9.9,3 C 9.6,3 9.3,3.3 9.3,3.6 L 8.9,5.8 C 8.3,6 7.8,6.3 7.3,6.7 L 5.2,5.1 C 5,4.9 4.6,4.9 4.5,5.1 L 2.5,8.6 C 2.3,8.8 2.3,9.2 2.5,9.3 L 4.6,11 C 4.4,11.3 4.3,11.6 4.3,12 C 4.3,12.4 4.4,12.7 4.6,13 L 2.5,14.7 C 2.3,14.8 2.3,15.2 2.5,15.4 L 4.5,18.9 C 4.6,19.1 5,19.1 5.2,18.9 L 7.3,17.3 C 7.8,17.7 8.3,18 8.9,18.2 L 9.3,20.4 C 9.3,20.7 9.6,21 9.9,21 L 14.1,21 C 14.4,21 14.7,20.7 14.7,20.4 L 15.1,18.2 C 15.7,18 16.2,17.7 16.7,17.3 L 18.8,18.9 C 19,19.1 19.4,19.1 19.5,18.9 L 21.5,15.4 C 21.7,15.2 21.7,14.8 21.5,14.7 Z"
                        Width="18" Height="18"
                        Foreground="{DynamicResource TextSecondaryBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
            </Button>
          </StackPanel>
        </StackPanel>

        <!-- Server list -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*,Auto">
          <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="6,4" />

          <ScrollViewer Grid.Row="1" Margin="0,2">
            <StackPanel HorizontalAlignment="Center" Spacing="2">
              <ItemsControl ItemsSource="{Binding Servers}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type models:ServerInfo}">
                    <Button Classes="ghost" Width="42" Height="34" Padding="0"
                            Command="{Binding DataContext.ConnectToServerCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding}"
                            ToolTip.Tip="{Binding Name}">
                      <Border Width="28" Height="28" CornerRadius="8"
                              Background="{DynamicResource BgCardBrush}"
                              ClipToBounds="True">
                        <Grid>
                          <Image Source="{Binding Icon}" Stretch="UniformToFill"
                                 IsVisible="{Binding Icon, Converter={StaticResource IsNotNullConverter}}" />
                          <TextBlock Text="{Binding Name, Converter={StaticResource FirstCharConverter}}"
                                     FontSize="11" FontWeight="Bold"
                                     Foreground="{DynamicResource AccentBrush}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     IsVisible="{Binding Icon, Converter={StaticResource IsNullConverter}}" />
                        </Grid>
                      </Border>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </ScrollViewer>

          <!-- Add server button -->
          <Button Grid.Row="2" Classes="ghost" Width="42" Height="34"
                  Padding="0" Margin="0,2,0,6"
                  Command="{Binding ShowAddServerCommand}"
                  ToolTip.Tip="Add Server">
            <Border Width="28" Height="28" CornerRadius="8"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1.5"
                    Background="Transparent">
              <TextBlock Text="+" FontSize="16" FontWeight="Bold"
                         Foreground="{DynamicResource TextMutedBrush}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Border>
          </Button>
        </Grid>

        <!-- Bottom: Player avatar -->
        <Button Grid.Row="2"
                Command="{Binding OpenPlayerSetupCommand}"
                Classes="ghost"
                Width="42" Height="42"
                Padding="0"
                Margin="0,0,0,14"
                ToolTip.Tip="Account">
          <Border Width="34" Height="34" CornerRadius="10"
                  Background="{DynamicResource AccentBrush}">
            <TextBlock Text="{Binding PlayerInitial, FallbackValue='?'}"
                       FontSize="14" FontWeight="Bold"
                       Foreground="#000000"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
        </Button>
      </Grid>
    </Border>

    <!-- Sidebar separator -->
    <Border Grid.Column="1"
            Background="{DynamicResource BorderBrush}" />

    <!-- ═══════════ INSTANCE LIST PANEL ═══════════ -->
    <Border Grid.Column="2"
            Background="{DynamicResource BgSidebarBrush}">
      <Grid RowDefinitions="Auto,Auto,*">
        <!-- Header -->
        <Border Grid.Row="0" Padding="18,18,18,12">
          <StackPanel Spacing="10">
            <TextBlock Text="{Binding Localization[menu.instances]}"
                       FontSize="11" FontWeight="Bold"
                       Foreground="{DynamicResource TextMutedBrush}"
                       LetterSpacing="1.2" />
            <Button Command="{Binding AddInstanceCommand}"
                    Classes="secondary"
                    Height="36"
                    HorizontalAlignment="Stretch">
              <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                <TextBlock Text="+" FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}" />
                <TextBlock Text="{Binding Localization[menu.newinstance]}" FontSize="12"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </StackPanel>
        </Border>

        <Border Grid.Row="1" Height="1"
                Background="{DynamicResource BorderBrush}"
                Margin="14,0" />

        <!-- Instance list -->
        <ScrollViewer Grid.Row="2" Margin="8,6">
          <ItemsControl ItemsSource="{Binding GroupedInstanceList}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="{x:Type models:InstanceGroupItem}">
                <Grid Margin="0,1">
                  <!-- Group header -->
                  <Border IsVisible="{Binding IsGroup}"
                          Padding="10,8,10,4">
                    <TextBlock Text="{Binding GroupName}"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextMutedBrush}" />
                  </Border>

                  <!-- Instance item -->
                  <Button Classes="instanceBtn"
                          IsVisible="{Binding IsGroup, Converter={StaticResource InverseBool}}"
                          Command="{Binding DataContext.SelectInstanceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                          CommandParameter="{Binding Instance}"
                          Padding="10,8" HorizontalAlignment="Stretch">
                    <Grid ColumnDefinitions="34,*">
                      <Border Width="34" Height="34" CornerRadius="8"
                              Background="{DynamicResource BgCardBrush}"
                              BorderBrush="{DynamicResource BorderBrush}"
                              BorderThickness="1">
                        <TextBlock Text="{Binding Instance.Icon}"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                      </Border>
                      <StackPanel Grid.Column="1" Margin="10,0,0,0"
                                  VerticalAlignment="Center">
                        <TextBlock Text="{Binding Instance.DisplayName}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding Instance.LoaderLabel}"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   TextTrimming="CharacterEllipsis" />
                      </StackPanel>
                    </Grid>
                  </Button>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

    <!-- ═══════════ MAIN CONTENT ═══════════ -->
    <Grid Grid.Column="3" RowDefinitions="*,Auto"
          Background="{DynamicResource BgSecondaryBrush}">

      <!-- Center content -->
      <StackPanel Grid.Row="0"
                  VerticalAlignment="Center" HorizontalAlignment="Center"
                  Spacing="24">
        <TextBlock Text="LauncherRoot"
                   Classes="h1"
                   HorizontalAlignment="Center" />

        <!-- Selected instance card -->
        <Border Classes="card"
                Padding="0"
                IsVisible="{Binding HasInstances}"
                MinWidth="420" MaxWidth="500">
          <StackPanel Spacing="0">
            <!-- Instance info -->
            <StackPanel Spacing="6" HorizontalAlignment="Center" Margin="32,24,32,16">
              <TextBlock Text="{Binding Localization[instance.selected]}"
                         FontSize="11" FontWeight="Bold"
                         Foreground="{DynamicResource TextMutedBrush}"
                         HorizontalAlignment="Center"
                         LetterSpacing="1.5" />
              <TextBlock Text="{Binding SelectedInstance.DisplayName, FallbackValue='-'}"
                         FontSize="26" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         HorizontalAlignment="Center"
                         TextTrimming="CharacterEllipsis" />
              <TextBlock Text="{Binding SelectedInstance.Version, FallbackValue=''}"
                         FontSize="13"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         HorizontalAlignment="Center" />
              <TextBlock Text="{Binding SelectedInstance.PlayTimeLabel, FallbackValue=''}"
                         FontSize="11"
                         Foreground="{DynamicResource TextMutedBrush}"
                         HorizontalAlignment="Center"
                         IsVisible="{Binding HasInstances}" />
            </StackPanel>

            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="20,0" />

            <!-- Action buttons row -->
            <Grid Margin="16,12" ColumnDefinitions="*,*,*,*,*">
              <Button Classes="ghost" Padding="0,6" HorizontalAlignment="Center"
                      Command="{Binding EditInstanceCommand}"
                      CommandParameter="{Binding SelectedInstance}"
                      ToolTip.Tip="Edit Instance">
                <StackPanel Spacing="4">
                  <PathIcon Data="M 3,17.25 L 3,21 L 6.75,21 L 17.81,9.94 L 14.06,6.19 Z M 20.71,7.04 C 21.1,6.65 21.1,6.02 20.71,5.63 L 18.37,3.29 C 17.98,2.9 17.35,2.9 16.96,3.29 L 15.13,5.12 L 18.88,8.87 Z"
                            Width="16" Height="16"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            HorizontalAlignment="Center" />
                  <TextBlock Text="{Binding Localization[instance.edit]}" FontSize="10"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             HorizontalAlignment="Center" />
                </StackPanel>
              </Button>

              <Button Grid.Column="1" Classes="ghost" Padding="0,6" HorizontalAlignment="Center"
                      Command="{Binding BackupNowCommand}"
                      CommandParameter="{Binding SelectedInstance}"
                      ToolTip.Tip="Backup">
                <StackPanel Spacing="4">
                  <PathIcon Data="M 5,3 L 19,3 C 20.1,3 21,3.9 21,5 L 21,19 C 21,20.1 20.1,21 19,21 L 5,21 C 3.9,21 3,20.1 3,19 L 3,5 C 3,3.9 3.9,3 5,3 Z M 5,5 L 5,19 L 19,19 L 19,5 Z M 11,7 L 13,7 L 13,11 L 17,11 L 17,13 L 13,13 L 13,17 L 11,17 L 11,13 L 7,13 L 7,11 L 11,11 Z"
                            Width="16" Height="16"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            HorizontalAlignment="Center" />
                  <TextBlock Text="{Binding Localization[backup.now]}" FontSize="10"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             HorizontalAlignment="Center" />
                </StackPanel>
              </Button>

              <Button Grid.Column="2" Classes="ghost" Padding="0,6" HorizontalAlignment="Center"
                      Command="{Binding OpenInstanceFolderCommand}"
                      CommandParameter="{Binding SelectedInstance}"
                      ToolTip.Tip="Open Folder">
                <StackPanel Spacing="4">
                  <PathIcon Data="M 10,4 L 4,4 C 2.9,4 2,4.9 2,6 L 2,18 C 2,19.1 2.9,20 4,20 L 20,20 C 21.1,20 22,19.1 22,18 L 22,8 C 22,6.9 21.1,6 20,6 L 12,6 L 10,4 Z"
                            Width="16" Height="16"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            HorizontalAlignment="Center" />
                  <TextBlock Text="{Binding Localization[menu.openfolder]}" FontSize="10"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             HorizontalAlignment="Center" />
                </StackPanel>
              </Button>

              <Button Grid.Column="3" Classes="ghost" Padding="0,6" HorizontalAlignment="Center"
                      Command="{Binding ExportInstanceCommand}"
                      CommandParameter="{Binding SelectedInstance}"
                      ToolTip.Tip="Export">
                <StackPanel Spacing="4">
                  <PathIcon Data="M 19,9 L 17.59,9 L 17.59,7.41 L 12,13 L 17.59,18.59 L 19,17.17 L 14.83,13 Z M 5,5 L 19,5 C 20.1,5 21,5.9 21,7 L 21,19 C 21,20.1 20.1,21 19,21 L 5,21 C 3.9,21 3,20.1 3,19 L 3,7 C 3,5.9 3.9,5 5,5 Z M 5,7 L 5,19 L 19,19 L 19,7 Z"
                            Width="16" Height="16"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            HorizontalAlignment="Center" />
                  <TextBlock Text="{Binding Localization[menu.export]}" FontSize="10"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             HorizontalAlignment="Center" />
                </StackPanel>
              </Button>

              <Button Grid.Column="4" Classes="ghost" Padding="0,6" HorizontalAlignment="Center"
                      Command="{Binding DeleteInstanceCommand}"
                      CommandParameter="{Binding SelectedInstance}"
                      ToolTip.Tip="Delete">
                <StackPanel Spacing="4">
                  <PathIcon Data="M 6,19 C 6,20.1 6.9,21 8,21 L 16,21 C 17.1,21 18,20.1 18,19 L 18,7 L 6,7 Z M 15.5,4 L 14.5,3 L 9.5,3 L 8.5,4 L 5,4 L 5,6 L 19,6 L 19,4 Z"
                            Width="16" Height="16"
                            Foreground="{DynamicResource ErrorBrush}"
                            HorizontalAlignment="Center" />
                  <TextBlock Text="{Binding Localization[instance.delete]}" FontSize="10"
                             Foreground="{DynamicResource ErrorBrush}"
                             HorizontalAlignment="Center" />
                </StackPanel>
              </Button>
            </Grid>
          </StackPanel>
        </Border>

        <!-- No instances -->
        <Border Classes="card"
                Padding="40,28"
                IsVisible="{Binding HasInstances, Converter={StaticResource InverseBool}}"
                MinWidth="380">
          <TextBlock Text="{Binding Localization[menu.noinstances]}"
                     FontSize="14"
                     Foreground="{DynamicResource TextMutedBrush}"
                     HorizontalAlignment="Center" />
        </Border>
      </StackPanel>

      <!-- Bottom play bar -->
      <Border Grid.Row="1"
              Background="{DynamicResource BgCardBrush}"
              BorderThickness="0,1,0,0"
              BorderBrush="{DynamicResource BorderBrush}"
              Padding="20,12">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto">
          <!-- Player info -->
          <Button Command="{Binding OpenPlayerSetupCommand}"
                  Classes="ghost" Padding="6,4"
                  Cursor="Hand">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Width="30" Height="30" CornerRadius="8"
                      Background="{DynamicResource AccentBrush}">
                <TextBlock Text="{Binding PlayerInitial, FallbackValue='?'}"
                           FontSize="12" FontWeight="Bold"
                           Foreground="#000000"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </Border>
              <TextBlock Text="{Binding PlayerUsername, FallbackValue='Player'}"
                         FontSize="12" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <!-- Secondary actions -->
          <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                      Spacing="2">
            <Button Classes="ghost" Padding="6,4"
                    Command="{Binding ImportInstanceCommand}"
                    ToolTip.Tip="Import">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <PathIcon Data="M 5,20 L 19,20 C 20.1,20 21,19.1 21,18 L 21,6 C 21,4.9 20.1,4 19,4 L 5,4 C 3.9,4 3,4.9 3,6 L 3,18 C 3,19.1 3.9,20 5,20 Z M 12,12 L 12,3 L 16.59,7.58 L 15.17,9 L 12,5.83 Z M 8,14 L 10,14 L 10,18 L 14,18 L 14,14 L 16,14 L 12,10 Z"
                          Width="14" Height="14"
                          Foreground="{DynamicResource TextMutedBrush}" />
                <TextBlock Text="{Binding Localization[menu.import]}" FontSize="10"
                           Foreground="{DynamicResource TextMutedBrush}" />
              </StackPanel>
            </Button>
            <Button Classes="ghost" Padding="6,4"
                    Command="{Binding DuplicateInstanceCommand}"
                    CommandParameter="{Binding SelectedInstance}"
                    ToolTip.Tip="Duplicate">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <PathIcon Data="M 16,1 L 4,1 C 2.9,1 2,1.9 2,3 L 2,17 L 4,17 L 4,3 L 16,3 Z M 19,5 L 8,5 C 6.9,5 6,5.9 6,7 L 6,21 C 6,22.1 6.9,23 8,23 L 19,23 C 20.1,23 21,22.1 21,21 L 21,7 C 21,5.9 20.1,5 19,5 Z M 19,21 L 8,21 L 8,7 L 19,7 Z"
                          Width="14" Height="14"
                          Foreground="{DynamicResource TextMutedBrush}" />
                <TextBlock Text="{Binding Localization[menu.duplicate]}" FontSize="10"
                           Foreground="{DynamicResource TextMutedBrush}" />
              </StackPanel>
            </Button>
            <Button Classes="ghost" Padding="6,4"
                    Command="{Binding OpenScreenshotGalleryCommand}"
                    CommandParameter="{Binding SelectedInstance}"
                    ToolTip.Tip="Screenshots">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <PathIcon Data="M 21,19 L 21,5 C 21,3.9 20.1,3 19,3 L 5,3 C 3.9,3 3,3.9 3,5 L 3,19 C 3,20.1 3.9,21 5,21 L 19,21 C 20.1,21 21,20.1 21,19 Z M 8.5,13.5 L 11,16.51 L 14.5,12 L 19,18 L 5,18 Z"
                          Width="14" Height="14"
                          Foreground="{DynamicResource TextMutedBrush}" />
                <TextBlock Text="{Binding Localization[menu.gallery]}" FontSize="10"
                           Foreground="{DynamicResource TextMutedBrush}" />
              </StackPanel>
            </Button>
            <Button Classes="ghost" Padding="6,4"
                    Command="{Binding OpenLogViewerCommand}"
                    ToolTip.Tip="Console">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <PathIcon Data="M 20,19 L 20,3 L 4,3 L 4,19 Z M 7,14 L 10,11 L 7,8 M 11,16 L 17,16"
                          Width="14" Height="14"
                          Foreground="{DynamicResource TextMutedBrush}" />
                <TextBlock Text="{Binding Localization[menu.console]}" FontSize="10"
                           Foreground="{DynamicResource TextMutedBrush}" />
              </StackPanel>
            </Button>
          </StackPanel>

          <!-- Play button -->
          <Button Command="{Binding PlayCommand}"
                  Grid.Column="2"
                  Classes="primary"
                  Width="220" Height="46"
                  FontSize="16"
                  FontWeight="Bold">
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
              <TextBlock Text="▶" FontSize="18" VerticalAlignment="Center" />
              <TextBlock Text="{Binding Localization[menu.play]}" VerticalAlignment="Center" />
            </StackPanel>
          </Button>

          <!-- Mod management -->
          <Button Command="{Binding OpenModManagementCommand}"
                  Grid.Column="3"
                  Classes="secondary"
                  Width="46" Height="46"
                  Padding="0" Margin="8,0,0,0"
                  IsVisible="{Binding HasInstances}"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center"
                  ToolTip.Tip="Mods">
            <PathIcon Data="M 20.5,11.5 L 19,7 L 15,7 L 15,3 L 9,3 L 9,7 L 5,7 L 3.5,11.5 L 3.5,22 L 20.5,22 Z M 9,5 L 15,5 L 15,7 L 9,7 Z M 5.5,9 L 8.5,9 L 8.5,14 L 5.5,14 Z M 15.5,9 L 18.5,9 L 18.5,14 L 15.5,14 Z M 5.5,16 L 8.5,16 L 8.5,20 L 5.5,20 Z M 15.5,16 L 18.5,16 L 18.5,20 L 15.5,20 Z M 10,10 L 14,10 L 14,14 L 10,14 Z M 10,16 L 14,16 L 14,20 L 10,20 Z"
                      Width="18" Height="18"
                      Foreground="{DynamicResource TextPrimaryBrush}" />
          </Button>

          <!-- Settings -->
          <Button Command="{Binding OpenSettingsCommand}"
                  Grid.Column="4"
                  Classes="ghost"
                  Width="40" Height="40"
                  Padding="0"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center">
            <PathIcon Data="M 12,15.5 A 3.5,3.5 0 1,1 12,8.5 A 3.5,3.5 0 1,1 12,15.5 M 19.4,13 C 19.2,12.7 19.1,12.4 19.1,12 C 19.1,11.6 19.2,11.3 19.4,11 L 21.5,9.3 C 21.7,9.2 21.7,8.8 21.5,8.6 L 19.5,5.1 C 19.4,4.9 19,4.9 18.8,5.1 L 16.7,6.7 C 16.2,6.3 15.7,6 15.1,5.8 L 14.7,3.6 C 14.7,3.3 14.4,3 14.1,3 L 9.9,3 C 9.6,3 9.3,3.3 9.3,3.6 L 8.9,5.8 C 8.3,6 7.8,6.3 7.3,6.7 L 5.2,5.1 C 5,4.9 4.6,4.9 4.5,5.1 L 2.5,8.6 C 2.3,8.8 2.3,9.2 2.5,9.3 L 4.6,11 C 4.4,11.3 4.3,11.6 4.3,12 C 4.3,12.4 4.4,12.7 4.6,13 L 2.5,14.7 C 2.3,14.8 2.3,15.2 2.5,15.4 L 4.5,18.9 C 4.6,19.1 5,19.1 5.2,18.9 L 7.3,17.3 C 7.8,17.7 8.3,18 8.9,18.2 L 9.3,20.4 C 9.3,20.7 9.6,21 9.9,21 L 14.1,21 C 14.4,21 14.7,20.7 14.7,20.4 L 15.1,18.2 C 15.7,18 16.2,17.7 16.7,17.3 L 18.8,18.9 C 19,19.1 19.4,19.1 19.5,18.9 L 21.5,15.4 C 21.7,15.2 21.7,14.8 21.5,14.7 Z"
                      Width="18" Height="18"
                      Foreground="{DynamicResource TextMutedBrush}" />
          </Button>
        </Grid>
      </Border>
    </Grid>

    <!-- ═══════════ STATUS BAR ═══════════ -->
    <Border Grid.ColumnSpan="4"
            Background="{DynamicResource BgPrimaryBrush}"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource BorderBrush}"
            Padding="20,8"
            IsVisible="{Binding ShowStatusBar}">
      <StackPanel Spacing="6">
        <TextBlock Text="{Binding StatusText}"
                   FontSize="11"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   HorizontalAlignment="Center" />
        <ProgressBar Value="{Binding StatusProgress}"
                     Minimum="0" Maximum="1"
                     IsVisible="{Binding HasError, Converter={StaticResource InverseBool}}" />
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="8"
                    IsVisible="{Binding HasError}">
          <Button Command="{Binding CopyErrorCommand}"
                  Classes="secondary" Height="26" FontSize="11"
                  Padding="12,0">
            <TextBlock Text="{Binding Localization[menu.copyerror]}" />
          </Button>
          <Button Command="{Binding DismissErrorCommand}"
                  Classes="ghost" Height="26" FontSize="11"
                  Padding="12,0">
            <TextBlock Text="{Binding Localization[menu.dismiss]}" />
          </Button>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- ═══════════ BACKUP PANEL OVERLAY ═══════════ -->
    <Border Grid.ColumnSpan="4"
            Background="#80000000"
            IsVisible="{Binding ShowBackupPanel}"
            ZIndex="100">
      <Border Background="{DynamicResource BgCardBrush}"
              CornerRadius="16"
              Width="420"
              MaxHeight="460"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Padding="24">
        <StackPanel Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <PathIcon Data="M 2,8 L 12,2 L 22,8 L 22,22 L 2,22 Z M 7,22 L 7,13 L 17,13 L 17,22 M 7,8 L 7,13 M 17,8 L 17,13 M 12,8 L 12,22"
                      Width="20" Height="20"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      VerticalAlignment="Center" />
            <TextBlock Text="{Binding Localization[backup.title]}"
                       FontSize="17" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
          </StackPanel>

          <Border Height="1" Background="{DynamicResource BorderBrush}" />

          <ScrollViewer MaxHeight="300">
            <ItemsControl ItemsSource="{Binding AvailableBackups}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type models:BackupInfo}">
                  <Border Background="{DynamicResource BgSecondaryBrush}"
                          CornerRadius="10" Padding="14"
                          Margin="0,4">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                      <StackPanel>
                        <TextBlock Text="{Binding FileName}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding CreatedAt}"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                      </StackPanel>
                      <Button Grid.Column="1"
                              Command="{Binding DataContext.RestoreBackupCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                              CommandParameter="{Binding}"
                              Classes="secondary"
                              Height="28" Padding="10,0"
                              FontSize="11"
                              Margin="0,0,6,0"
                              VerticalAlignment="Center">
                        <TextBlock Text="{Binding DataContext.Localization[backup.restore], RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                      </Button>
                      <Button Grid.Column="2"
                              Command="{Binding DataContext.DeleteBackupCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                              CommandParameter="{Binding}"
                              Classes="ghost"
                              Height="28" Width="28"
                              FontSize="12"
                              VerticalAlignment="Center">
                        <TextBlock Text="✕" />
                      </Button>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <Border Height="1" Background="{DynamicResource BorderBrush}" />

          <Button Command="{Binding HideBackupsCommand}"
                  Classes="secondary"
                  Height="36"
                  HorizontalAlignment="Stretch">
            <TextBlock Text="{Binding Localization[menu.close]}" />
          </Button>
        </StackPanel>
      </Border>
    </Border>

    <!-- ═══════════ ADD SERVER OVERLAY ═══════════ -->
    <Border Grid.ColumnSpan="4"
            Background="#80000000"
            IsVisible="{Binding ShowAddServerDialog}"
            ZIndex="110">
      <Border Background="{DynamicResource BgCardBrush}"
              CornerRadius="16"
              Width="380"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Padding="24">
        <StackPanel Spacing="16">
          <TextBlock Text="Add Server"
                     FontSize="17" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />

          <Border Height="1" Background="{DynamicResource BorderBrush}" />

          <StackPanel Spacing="8">
            <TextBlock Text="Server Name" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBox Text="{Binding NewServerName}"
                     Watermark="e.g. Hypixel"
                     Height="36" FontSize="13" />
          </StackPanel>

          <StackPanel Spacing="8">
            <TextBlock Text="Server Address" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBox Text="{Binding NewServerAddress}"
                     Watermark="e.g. mc.hypixel.net"
                     Height="36" FontSize="13" />
          </StackPanel>

          <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
            <Button Command="{Binding HideAddServerCommand}"
                    Classes="secondary" Height="36" Margin="0,0,6,0"
                    FontSize="12">
              <TextBlock Text="{Binding Localization[microsoft.cancel]}" />
            </Button>
            <Button Grid.Column="1" Command="{Binding AddServerCommand}"
                    Classes="primary" Height="36" Margin="6,0,0,0"
                    FontSize="12">
              <TextBlock Text="Add" />
            </Button>
          </Grid>
        </StackPanel>
      </Border>
    </Border>
  </Grid>
</UserControl>
