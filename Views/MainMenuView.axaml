<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LauncherRoot.ViewModels"
             x:Class="LauncherRoot.Views.MainMenuView">
  <Grid RowDefinitions="Auto,*,Auto,Auto">
    <!-- Top bar: Settings gear -->
    <Grid ColumnDefinitions="Auto,*,Auto" Grid.Row="0" Margin="16,12">
      <Button Command="{Binding OpenSettingsCommand}"
              FontSize="28"
              Width="48"
              Height="48"
              BorderThickness="0"
              Background="Transparent"
              Cursor="Hand">
        <TextBlock Text="⚙" />
      </Button>
    </Grid>

    <!-- Center: Logo -->
    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
      <TextBlock Text="🎮"
                 FontSize="36"
                 HorizontalAlignment="Center"
                 Opacity="0.5" />
      <TextBlock Text="LauncherRoot"
                 FontSize="52"
                 FontWeight="Bold"
                 HorizontalAlignment="Center" />
      <TextBlock Text="{Binding PlayerUsername, FallbackValue=''}"
                 FontSize="18"
                 HorizontalAlignment="Center"
                 Opacity="0.7" />
    </StackPanel>

    <!-- Status bar -->
    <Border Grid.Row="2"
            Background="#2D2D2D"
            CornerRadius="8"
            Padding="16,10"
            Margin="40,0,40,12"
            IsVisible="{Binding ShowStatusBar}">
      <StackPanel Spacing="8">
        <TextBlock Text="{Binding StatusText}"
                   FontSize="13"
                   HorizontalAlignment="Center" />
        <ProgressBar Value="{Binding StatusProgress}"
                     Height="6"
                     Minimum="0"
                     Maximum="1" />
      </StackPanel>
    </Border>

    <!-- Bottom buttons -->
    <Grid Grid.Row="3"
          ColumnDefinitions="*,Auto,Auto,*"
          Margin="0,0,0,40">
      <Button Command="{Binding OpenModManagementCommand}"
              Grid.Column="1"
              Width="190"
              Height="55"
              FontSize="17"
              Margin="0,0,12,0">
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
          <TextBlock Text="📦" FontSize="20" VerticalAlignment="Center" />
          <TextBlock Text="{Binding Localization[menu.modmanagement]}" VerticalAlignment="Center" />
        </StackPanel>
      </Button>

      <Button Command="{Binding PlayCommand}"
              Grid.Column="2"
              Width="210"
              Height="65"
              FontSize="22"
              FontWeight="Bold">
        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
          <TextBlock Text="▶" FontSize="24" VerticalAlignment="Center" />
          <TextBlock Text="{Binding Localization[menu.play]}" VerticalAlignment="Center" />
        </StackPanel>
      </Button>
    </Grid>
  </Grid>
</UserControl>
