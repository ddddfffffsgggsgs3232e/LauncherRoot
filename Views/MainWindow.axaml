<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LauncherRoot.ViewModels;assembly=LauncherRoot"
        xmlns:views="clr-namespace:LauncherRoot.Views;assembly=LauncherRoot"
        x:Class="LauncherRoot.Views.MainWindow"
        Title="{Binding WindowTitle}"
        Width="1024"
        Height="680"
        MinWidth="800"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        TransparencyLevelHint="Blur"
        Name="MainWin">
  <Window.DataTemplates>
    <DataTemplate DataType="{x:Type vm:PlayerSetupViewModel}">
      <views:PlayerSetupView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:ThemeSelectionViewModel}">
      <views:ThemeSelectionView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:SplashViewModel}">
      <views:SplashView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:MainMenuViewModel}">
      <views:MainMenuView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:ModManagementViewModel}">
      <views:ModManagementView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
      <views:SettingsView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:InstanceCreateViewModel}">
      <views:InstanceCreateView />
    </DataTemplate>
  </Window.DataTemplates>

  <Panel>
    <!-- Background gradient -->
    <Border Background="{DynamicResource BgPrimaryBrush}" />

    <!-- Old page (cross-fade out) -->
    <ContentControl x:Name="OldPageHost"
                    Classes="page"
                    IsHitTestVisible="False"
                    Opacity="0" />

    <!-- New page (cross-fade in) -->
    <ContentControl x:Name="NewPageHost"
                    Content="{Binding CurrentViewModel}"
                    Classes="page" />
  </Panel>
</Window>
