<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LauncherRoot.ViewModels"
             xmlns:models="clr-namespace:LauncherRoot.Models"
             x:Class="LauncherRoot.Views.PlayerSetupView">
  <Grid ColumnDefinitions="280,*" HorizontalAlignment="Center" VerticalAlignment="Center"
        Margin="40">
    <!-- LEFT: Saved accounts sidebar -->
    <Border Background="{DynamicResource BgSidebarBrush}"
            CornerRadius="12" Padding="16"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
      <StackPanel Spacing="12">
        <TextBlock FontSize="24" HorizontalAlignment="Center"
                   Foreground="{DynamicResource AccentBrush}"></TextBlock>
        <TextBlock Text="{Binding Localization[player.accounts]}"
                   FontSize="14" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   HorizontalAlignment="Center" />
        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="10,0" />
        <ListBox ItemsSource="{Binding Accounts}"
                 BorderThickness="0"
                 Background="Transparent"
                 Height="300">
          <ListBox.ItemTemplate>
            <DataTemplate DataType="{x:Type models:PlayerConfig}">
              <Button Classes="ghost" Padding="0" Margin="0,2" Cursor="Hand"
                      Command="{Binding DataContext.SelectAccountCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                      CommandParameter="{Binding}">
                <Border Padding="10,8" CornerRadius="8"
                        Background="{DynamicResource BgCardBrush}">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel VerticalAlignment="Center">
                      <TextBlock Text="{Binding Username}" FontSize="14" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimaryBrush}" />
                      <TextBlock Text="{Binding AuthType}" FontSize="11"
                                 Foreground="{DynamicResource TextMutedBrush}" />
                    </StackPanel>
                    <Button Grid.Column="1" Classes="ghost" Padding="4"
                            Command="{Binding DataContext.DeleteAccountCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                            CommandParameter="{Binding}">
                      </Button>
                  </Grid>
                </Border>
              </Button>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
        <TextBlock Text="{Binding Localization[player.clicktojoin]}"
                   FontSize="11"
                   Foreground="{DynamicResource TextMutedBrush}"
                   HorizontalAlignment="Center" />
      </StackPanel>
    </Border>

    <!-- RIGHT: Login area -->
    <ScrollViewer Grid.Column="1">
      <StackPanel Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40,0">
        <TextBlock Text="👤︎" FontSize="36" HorizontalAlignment="Center"
                   Foreground="{DynamicResource AccentBrush}" />
        <TextBlock Text="◆" FontSize="28" HorizontalAlignment="Center"
                   Foreground="{DynamicResource AccentBrush}" />
        <TextBlock Text="LauncherRoot" FontSize="36" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   HorizontalAlignment="Center" />
        <TextBlock Text="{Binding Localization[player.welcome]}"
                   Classes="h3" HorizontalAlignment="Center" Margin="0,0,0,12" />

        <!-- Offline mode card -->
        <Border Classes="card" Padding="24" Width="360">
          <StackPanel Spacing="14">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
              <TextBlock Text="{Binding Localization[player.offline]}"
                         FontSize="15" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>

            <TextBox Text="{Binding Username}"
                     Watermark="{Binding Localization[player.placeholder]}"
                     Height="42" FontSize="15"
                     HorizontalContentAlignment="Center" />

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource ErrorBrush}"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap" />

            <Button Command="{Binding ContinueCommand}"
                    Classes="secondary"
                    Width="200" Height="42"
                    FontSize="15"
                    HorizontalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <TextBlock Text="{Binding Localization[player.continue]}" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </StackPanel>
        </Border>

        <!-- Divider -->
        <Grid ColumnDefinitions="Auto,*,Auto" Width="200">
          <Border VerticalAlignment="Center" Height="1"
                  Background="{DynamicResource BorderBrush}" />
          <TextBlock Grid.Column="1" Text="{Binding Localization[player.or]}"
                     FontSize="13"
                     Foreground="{DynamicResource TextMutedBrush}"
                     HorizontalAlignment="Center"
                     Margin="12,0" />
          <Border Grid.Column="2" VerticalAlignment="Center" Height="1"
                  Background="{DynamicResource BorderBrush}" />
        </Grid>

        <!-- Microsoft login card -->
        <Border Classes="card" Padding="24" Width="360">
          <StackPanel Spacing="14">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
              <TextBlock Text="{Binding Localization[player.microsoft]}"
                         FontSize="15" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>

            <TextBlock Text="{Binding Localization[player.microsoftdesc]}"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" />

            <!-- Microsoft code display -->
            <Border Background="{DynamicResource BgSecondaryBrush}"
                    CornerRadius="10" Padding="20"
                    IsVisible="{Binding ShowMicrosoftCode}">
              <StackPanel Spacing="12" HorizontalAlignment="Center">
                <TextBlock Text="{Binding MicrosoftStatus}"
                           FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding Localization[microsoft.yourcode]}"
                           FontSize="12"
                           Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center" />
                <Border Background="{DynamicResource BgCardBrush}"
                        CornerRadius="8" Padding="16,10"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="2">
                  <TextBlock Text="{Binding MicrosoftCode}"
                             FontSize="28" FontWeight="Bold"
                             Foreground="{DynamicResource AccentBrush}"
                             LetterSpacing="4"
                             HorizontalAlignment="Center" />
                </Border>
                <TextBlock FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center">
                  <Run Text="{Binding Localization[microsoft.visit]}" />
                  <LineBreak />
                  <Run Text="{Binding MicrosoftUrl}" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" />
                  <LineBreak />
                  <Run Text="{Binding Localization[microsoft.entercode]}" />
                </TextBlock>
                <Button Command="{Binding CancelMicrosoftCommand}"
                        Classes="ghost"
                        HorizontalAlignment="Center"
                        FontSize="12">
                  <TextBlock Text="{Binding Localization[microsoft.cancel]}" />
                </Button>
              </StackPanel>
            </Border>

            <Button Command="{Binding MicrosoftLoginCommand}"
                    Classes="primary"
                    Height="44"
                    HorizontalAlignment="Stretch"
                    IsVisible="{Binding ShowMicrosoftCode, Converter={StaticResource InverseBool}}"
                    IsEnabled="{Binding IsMicrosoftLoggingIn, Converter={StaticResource InverseBool}}">
              <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <TextBlock Text="{Binding Localization[microsoft.login]}" FontSize="15" VerticalAlignment="Center" />
              </StackPanel>
            </Button>

            <TextBlock Text="{Binding Localization[player.microsoftnote]}"
                       FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
