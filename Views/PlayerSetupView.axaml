<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LauncherRoot.ViewModels"
             x:Class="LauncherRoot.Views.PlayerSetupView">
  <Grid RowDefinitions="*,Auto,Auto,Auto,*"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Width="420">
    <!-- Logo / Welcome -->
    <StackPanel Grid.Row="0" VerticalAlignment="Bottom" HorizontalAlignment="Center" Spacing="4">
      <TextBlock Text="LauncherRoot"
                 FontSize="48"
                 FontWeight="Bold"
                 HorizontalAlignment="Center" />
      <TextBlock Text="🎮"
                 FontSize="32"
                 HorizontalAlignment="Center"
                 Opacity="0.6" />
    </StackPanel>

    <!-- Welcome text -->
    <TextBlock Text="{Binding Localization[player.welcome]}"
               FontSize="18"
               HorizontalAlignment="Center"
               Grid.Row="1"
               Margin="0,24,0,10" />

    <!-- Username input -->
    <StackPanel Grid.Row="2" Spacing="10" HorizontalAlignment="Center">
      <TextBlock Text="{Binding Localization[player.name]}"
                 FontSize="14"
                 HorizontalAlignment="Center" />
      <TextBox Text="{Binding Username}"
               Watermark="{Binding Localization[player.placeholder]}"
               Width="320"
               Height="44"
               FontSize="16"
               HorizontalContentAlignment="Center" />
      <TextBlock Text="{Binding ErrorMessage}"
                 Foreground="Red"
                 FontSize="12"
                 HorizontalAlignment="Center" />
    </StackPanel>

    <!-- Continue button -->
    <Button Command="{Binding ContinueCommand}"
            Grid.Row="3"
            Margin="0,24,0,0"
            Width="220"
            Height="48"
            FontSize="18"
            HorizontalAlignment="Center">
      <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
        <TextBlock Text="➜" FontSize="20" VerticalAlignment="Center" />
        <TextBlock Text="{Binding Localization[player.continue]}" VerticalAlignment="Center" />
      </StackPanel>
    </Button>
  </Grid>
</UserControl>
