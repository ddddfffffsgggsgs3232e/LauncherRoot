<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="LauncherRoot.Views.SettingsView">
  <Grid RowDefinitions="Auto,*">
    <!-- Back button row -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,12">
      <Button Command="{Binding BackCommand}"
              Classes="ghost"
              Width="110" Height="36"
              FontSize="14">
        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
          <TextBlock Text="←" FontSize="16" VerticalAlignment="Center" />
          <TextBlock Text="{Binding Localization[menu.back]}" VerticalAlignment="Center" />
        </StackPanel>
      </Button>
    </StackPanel>

    <!-- Content -->
    <ScrollViewer Grid.Row="1" Margin="40,0,40,20">
      <StackPanel Spacing="24" HorizontalAlignment="Center" Width="820">
        <!-- Reset card (top, separate, danger) -->
        <Border Classes="card" Padding="20"
                BorderBrush="{DynamicResource ErrorBrush}" BorderThickness="1">
          <Grid ColumnDefinitions="Auto,*,Auto">
            <Border Width="40" Height="40" CornerRadius="8"
                    Background="#33F87171" VerticalAlignment="Center">
              <TextBlock Text="⚠︎" FontSize="22" Foreground="#F87171"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Border>
            <StackPanel Grid.Column="1" Margin="14,0,14,0" VerticalAlignment="Center">
              <TextBlock Text="{Binding Localization[settings.reset]}"
                         FontSize="15" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="{Binding Localization[settings.resetdesc]}"
                         FontSize="12"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
            </StackPanel>
            <Button Grid.Column="2" Classes="danger" Height="38" Width="100"
                    Command="{Binding ResetLauncherCommand}"
                    VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                <TextBlock Text="{Binding Localization[settings.resetbtn]}" FontSize="13" />
              </StackPanel>
            </Button>
          </Grid>
        </Border>

      <Grid HorizontalAlignment="Center" Width="820"
            ColumnDefinitions="400,20,400"
            RowDefinitions="Auto,20,Auto,20,Auto,20,Auto,20,Auto,20,Auto,20,Auto,20,Auto,20,Auto,20,Auto,20,Auto">
        <TextBlock Grid.ColumnSpan="3"
                   Text="{Binding Localization[settings.title]}"
                   Classes="h1"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0" />

        <!-- ── Row 1: RAM + FPS ── -->
        <Border Grid.Row="2" Classes="card" Padding="20">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="◆" FontSize="18" VerticalAlignment="Center" />
              <TextBlock FontSize="16" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         VerticalAlignment="Center">
                <Run Text="{Binding Localization[settings.ram]}" />
                <Run Text="{Binding RamGB, StringFormat=': {0} GB'}" />
              </TextBlock>
            </StackPanel>
            <Slider Minimum="1" Maximum="16" TickFrequency="1"
                    Value="{Binding RamGB}" IsSnapToTickEnabled="True" />
            <Grid ColumnDefinitions="*,*">
              <TextBlock Text="1 GB" FontSize="11"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBlock Text="16 GB" Grid.Column="1" FontSize="11"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         HorizontalAlignment="Right" />
            </Grid>
          </StackPanel>
        </Border>
        <Border Grid.Row="2" Grid.Column="2" Classes="card" Padding="20">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="🖥︎" FontSize="18" VerticalAlignment="Center" />
              <TextBlock Text="{Binding Localization[settings.fps]}"
                         FontSize="16" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
            <ComboBox ItemsSource="{Binding FpsOptions}"
                      SelectedIndex="{Binding SelectedFpsIndex}"
                      Height="38" Width="200" HorizontalAlignment="Left" />
          </StackPanel>
        </Border>

        <!-- ── Row 2: Theme + Language ── -->
        <Border Grid.Row="4" Classes="card" Padding="20">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="🎨︎" FontSize="18" VerticalAlignment="Center" />
              <TextBlock Text="{Binding Localization[settings.theme]}"
                         FontSize="16" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
            <Grid ColumnDefinitions="*,Auto,Auto">
              <TextBlock Text="{Binding Localization[settings.theme.light]}" FontSize="14"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         VerticalAlignment="Center" />
              <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsDarkTheme}"
                            Margin="12,0,8,0" />
              <TextBlock Text="{Binding Localization[settings.theme.dark]}" FontSize="14"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         Grid.Column="2" VerticalAlignment="Center" />
            </Grid>
          </StackPanel>
        </Border>
        <Border Grid.Row="4" Grid.Column="2" Classes="card" Padding="20">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="🌐︎" FontSize="18" VerticalAlignment="Center" />
              <TextBlock Text="{Binding Localization[settings.language]}"
                         FontSize="16" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
            <Grid ColumnDefinitions="*,Auto,Auto">
              <TextBlock Text="EN" FontSize="14"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         VerticalAlignment="Center" />
              <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsTurkish}"
                            Margin="12,0,8,0" />
              <TextBlock Text="TR" FontSize="14"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         Grid.Column="2" VerticalAlignment="Center" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- ── Row 3: Java Path + Resolution ── -->
        <Border Grid.Row="6" Classes="card" Padding="20">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="☕" FontSize="18" VerticalAlignment="Center" />
              <TextBlock Text="{Binding Localization[settings.java]}"
                         FontSize="16" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
            <Grid ColumnDefinitions="*,Auto">
              <TextBox Text="{Binding JavaPath}"
                       Watermark="{Binding Localization[settings.java.placeholder]}"
                       Height="40" FontSize="13" />
              <Button Grid.Column="1" Classes="secondary" Height="40" Width="100" Margin="8,0,0,0"
                      Command="{Binding BrowseJavaCommand}">
                <TextBlock Text="{Binding Localization[settings.java.browse]}" VerticalAlignment="Center" />
              </Button>
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="{Binding Localization[settings.java.detecting]}"
                         FontSize="11"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         IsVisible="{Binding IsDownloadingJava}" />
              <TextBlock Text="{Binding JavaStatusText}"
                         FontSize="11"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         TextTrimming="CharacterEllipsis" />
              <Button Command="{Binding DownloadJavaCommand}"
                      Classes="secondary"
                      Height="28" Padding="10 0"
                      FontSize="11"
                      IsVisible="{Binding IsJavaInstalled, Converter={StaticResource InverseBool}}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="⬇" FontSize="11" />
                  <TextBlock Text="{Binding Localization[settings.java.download]}" />
                </StackPanel>
              </Button>
            </StackPanel>
          </StackPanel>
        </Border>
        <Border Grid.Row="6" Grid.Column="2" Classes="card" Padding="20">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="{Binding Localization[settings.resolution]}"
                         FontSize="16" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Spacing="6">
              <TextBlock Text="G:" FontSize="14" VerticalAlignment="Center"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBox Text="{Binding WindowWidth}" Height="36" FontSize="14" Width="70" />
              <TextBlock Text="×" FontSize="14" VerticalAlignment="Center"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
              <TextBox Text="{Binding WindowHeight}" Height="36" FontSize="14" Width="70" />
              <TextBlock Text="px" FontSize="14" VerticalAlignment="Center"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ── Row 4: JVM Arguments (full width) ── -->
        <Border Grid.Row="8" Grid.ColumnSpan="3" Classes="card" Padding="20">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="⚙︎" FontSize="18" VerticalAlignment="Center" />
              <TextBlock Text="{Binding Localization[settings.jvmargs]}"
                         FontSize="16" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
            <TextBox Text="{Binding JvmArgs}"
                     Watermark="{Binding Localization[settings.jvmargs.placeholder]}"
                     Height="40" FontSize="13"
                     FontFamily="Consolas, monospace" />
          </StackPanel>
        </Border>

        <!-- ── Row 5: Pre-launch + Wrapper ── -->
        <Border Grid.Row="10" Classes="card" Padding="20">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="🚀︎" FontSize="18" VerticalAlignment="Center" />
              <TextBlock Text="{Binding Localization[settings.prelaunch]}"
                         FontSize="16" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
            <TextBox Text="{Binding PreLaunchCommand}"
                     Watermark="{Binding Localization[settings.prelaunch.placeholder]}"
                     Height="40" FontSize="13"
                     FontFamily="Consolas, monospace" />
          </StackPanel>
        </Border>
        <Border Grid.Row="10" Grid.Column="2" Classes="card" Padding="20">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="📦︎" FontSize="18" VerticalAlignment="Center" />
              <TextBlock Text="{Binding Localization[settings.wrapper]}"
                         FontSize="16" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
            <TextBox Text="{Binding WrapperCommand}"
                     Watermark="{Binding Localization[settings.wrapper.placeholder]}"
                     Height="40" FontSize="13"
                     FontFamily="Consolas, monospace" />
          </StackPanel>
        </Border>

        <!-- ── Row 6: Post-exit ── -->
        <Border Grid.Row="12" Classes="card" Padding="20">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="🔚︎" FontSize="18" VerticalAlignment="Center" />
              <TextBlock Text="{Binding Localization[settings.postexit]}"
                         FontSize="16" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
            <TextBox Text="{Binding PostExitCommand}"
                     Watermark="{Binding Localization[settings.postexit.placeholder]}"
                     Height="40" FontSize="13"
                     FontFamily="Consolas, monospace" />
          </StackPanel>
        </Border>

        <!-- ── Row 7: Microsoft Client ID (full width) ── -->
        <Border Grid.Row="14" Grid.ColumnSpan="3" Classes="card" Padding="20">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="☁︎" FontSize="18" VerticalAlignment="Center" />
              <TextBlock Text="{Binding Localization[settings.microsoft_clientid]}"
                         FontSize="16" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
            <TextBox Text="{Binding MicrosoftClientId}"
                     Watermark="{Binding Localization[settings.microsoft_clientid.placeholder]}"
                     Height="40" FontSize="13"
                     FontFamily="Consolas, monospace" />
            <TextBlock Text="{Binding Localization[settings.microsoft_clientid.hint]}"
                       FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <!-- ── Row 8: Updates (full width) ── -->
        <Border Grid.Row="16" Grid.ColumnSpan="3" Classes="card" Padding="20">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="🔄︎" FontSize="18" VerticalAlignment="Center" />
              <TextBlock Text="{Binding Localization[settings.update]}"
                         FontSize="16" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
            <TextBlock Text="{Binding CurrentVersion}"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Command="{Binding CheckForUpdatesCommand}"
                      Classes="secondary"
                      Height="34" Padding="14 0"
                      FontSize="13">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="{Binding Localization[settings.update.check]}" />
                </StackPanel>
              </Button>
              <TextBlock Text="{Binding UpdateStatus}"
                         FontSize="11"
                         Foreground="{DynamicResource AccentBrush}"
                         VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <ProgressBar Value="0" Minimum="0" Maximum="1"
                         IsVisible="{Binding IsCheckingUpdate}"
                         IsIndeterminate="True"
                         Height="4" />
          </StackPanel>
        </Border>

        <!-- ── Row 9: Desktop Shortcut ── -->
        <Border Grid.Row="18" Grid.ColumnSpan="3" Classes="card" Padding="20">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="🖥︎" FontSize="18" VerticalAlignment="Center" />
              <TextBlock Text="{Binding Localization[settings.installdesktop]}"
                         FontSize="16" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
            <Button Command="{Binding InstallDesktopCommand}"
                    Classes="secondary"
                    Height="34" Padding="14 0"
                    FontSize="13"
                    HorizontalAlignment="Left">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="{Binding Localization[settings.installdesktop]}" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </StackPanel>
        </Border>

        <!-- ── Row 10: CurseForge API Key ── -->
        <Border Grid.Row="20" Grid.ColumnSpan="3" Classes="card" Padding="20">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="🔑" FontSize="18" VerticalAlignment="Center" />
              <TextBlock Text="{Binding Localization[settings.curseforge]}"
                         FontSize="16" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
            <TextBox Text="{Binding CurseForgeApiKey}"
                     Watermark="{Binding Localization[settings.curseforge.placeholder]}"
                     Height="40" FontSize="13"
                     FontFamily="Consolas, monospace" />
            <TextBlock Text="{Binding Localization[settings.curseforge.hint]}"
                       FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </Grid>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
