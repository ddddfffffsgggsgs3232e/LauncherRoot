<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LauncherRoot.ViewModels"
             xmlns:models="clr-namespace:LauncherRoot.Models"
             x:Class="LauncherRoot.Views.ThemeSelectionView">
  <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="40">
    <TextBlock Text="{Binding Localization[theme.title]}"
               FontSize="28" FontWeight="Bold"
               HorizontalAlignment="Center" Grid.Row="0"
               Margin="0,20,0,0"
               Foreground="{DynamicResource TextPrimaryBrush}" />

    <TextBlock Text="{Binding Localization[theme.select]}"
               FontSize="14" HorizontalAlignment="Center"
               Grid.Row="1" Margin="0,8,0,24"
               Foreground="{DynamicResource TextSecondaryBrush}" />

    <ItemsControl ItemsSource="{Binding Themes}" Grid.Row="2"
                  HorizontalAlignment="Center">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <WrapPanel HorizontalAlignment="Center" />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate DataType="{x:Type models:Theme}">
          <Border Classes="card" Width="210" Height="250" Padding="0" Margin="8">
            <Button Background="Transparent"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    BorderThickness="0" CornerRadius="14"
                    Padding="18" Cursor="Hand"
                    Command="{Binding DataContext.SelectThemeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    CommandParameter="{Binding}">
              <Button.Styles>
                <Style Selector="Button">
                  <Setter Property="RenderTransform" Value="scale(1)" />
                  <Setter Property="Transitions">
                    <Transitions>
                      <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" />
                    </Transitions>
                  </Setter>
                </Style>
                <Style Selector="Button:pointerover">
                  <Setter Property="RenderTransform" Value="scale(1.03)" />
                </Style>
                <Style Selector="Button:pressed">
                  <Setter Property="RenderTransform" Value="scale(0.97)" />
                </Style>
              </Button.Styles>
              <StackPanel Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="{Binding Icon}" FontSize="42" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding LocalizedName}" FontSize="16" FontWeight="Bold"
                           HorizontalAlignment="Center" TextWrapping="Wrap" />
                <TextBlock Text="{Binding LocalizedDescription}" FontSize="11"
                           HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="170"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                <TextBlock Text="{Binding Mods.Count, StringFormat='{}{0} mods'}"
                           FontSize="11" HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextMutedBrush}" />
              </StackPanel>
            </Button>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <Border Classes="card" Padding="20" Grid.Row="3"
            VerticalAlignment="Bottom" IsVisible="{Binding IsDownloading}"
            Margin="0,20">
      <StackPanel Spacing="10">
        <TextBlock Text="{Binding Localization[theme.downloading]}"
                   FontSize="14" HorizontalAlignment="Center" />
        <ProgressBar Value="{Binding DownloadProgress}" Height="16"
                     Minimum="0" Maximum="1" />
        <TextBlock Text="{Binding ProgressText}" FontSize="12"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   HorizontalAlignment="Center" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
